{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "pre-commit-csharp",
         "command": "bash",
         "args": [ "csharp/.husky/pre-commit" ],
         "windows": {
            "command": "powershell",
            "args": [ "-ExecutionPolicy", "Bypass", "-File", "csharp/.husky/pre-commit.ps1" ]
         },
         "include": [ "csharp/**/*.cs", "csharp/**/*.csproj", "csharp/**/*.sln" ]
      },
      {
         "name": "pre-commit-go",
         "command": "bash",
         "args": [ "go/.husky/pre-commit" ],
         "include": [ "go/**/*.go", "go/**/go.mod" ]
      },
      {
         "name": "pre-commit-java",
         "command": "bash",
         "args": [ "java/.husky/pre-commit" ],
         "include": [ "java/**/*.java", "java/**/pom.xml" ]
      },
      {
         "name": "pre-commit-nodejs",
         "command": "bash",
         "args": [ "nodejs/.husky/pre-commit" ],
         "windows": {
            "command": "powershell",
            "args": [ "-ExecutionPolicy", "Bypass", "-File", "nodejs/.husky/pre-commit.ps1" ]
         },
         "include": [ "nodejs/**/*.ts", "nodejs/**/package.json", "nodejs/**/tsconfig.json" ]
      },
      {
         "name": "pre-commit-python",
         "command": "bash",
         "args": [ "python/.husky/pre-commit" ],
         "include": [ "python/**/*.py" ]
      }
   ]
}
