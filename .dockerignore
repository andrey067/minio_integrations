# .dockerignore for MinIO .NET project

# Git
.git/
.gitignore
.gitattributes

# Documentation
README.md
*.md
docs/

# IDE and editor files
.vs/
.vscode/
*.swp
*.swo
*~

# Build outputs
**/bin/
**/obj/
**/out/
build/
dist/

# Test results
TestResults/
test-results/
coverage/
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# Node.js (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.env
.venv

# Pre-commit
.pre-commit-config.yaml
.secrets.baseline

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.husky/
Makefile
build.ps1

# MinIO data (if running locally)
data/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS specific
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# User-specific files
*.suo
*.user
